Options -Indexes
RewriteEngine On

# 1) If user requests a directory URL like /servic/
# but that directory has NO index.html or index.php,
# redirect it to /servic.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html !-f
RewriteCond %{REQUEST_FILENAME}/index.php !-f
RewriteRule ^(.+?)/$ $1.html [L]

# 2) If file exists, serve it normally
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3) Otherwise fallback (optional)
RewriteRule ^ index.html [L]